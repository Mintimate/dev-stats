{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "build": {
    "command": "npm run build",
    "output": "dist"
  },
  "routes": [],
  "headers": [],
  "caches": [
    {
      "source": "/api",
      "cacheTtl": 86400
    },
    {
      "source": "/api/top-langs",
      "cacheTtl": 518400
    },
    {
      "source": "/api/pin",
      "cacheTtl": 864000
    },
    {
      "source": "/api/gist",
      "cacheTtl": 172800
    },
    {
      "source": "/api/wakatime",
      "cacheTtl": 86400
    },
    {
      "source": "/api/streak",
      "cacheTtl": 43200
    },
    {
      "source": "/api/profile-summary",
      "cacheTtl": 86400
    },
    {
      "source": "/api/contribution-calendar",
      "cacheTtl": 43200
    },
    {
      "source": "/api/recent-activity",
      "cacheTtl": 3600
    },
    {
      "source": "/api/repo-languages",
      "cacheTtl": 86400
    },
    {
      "source": "/api/org",
      "cacheTtl": 86400
    }
  ],
  "cloudFunctions": {
    "go": {
      "maxDuration": 30
    }
  },
  "agents": {
    "framework": "openai-agents-sdk",
    "externalNodeModules": ["openai", "@openai/agents"]
  }
}
